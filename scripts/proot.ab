import { env_var_get } from "std/env"
import { dir_create, file_chmod } from "std/fs"
import { file_download } from "std/http"

main {
    const install_dir = "{env_var_get("HOME")?}/.bootstrap"
    const proot_bin = "{install_dir}/proot"

    dir_create(install_dir)?
    file_download("https://proot.gitlab.io/proot/bin/proot", proot_bin)?
    file_chmod(proot_bin, "755")?
}
